generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Table {
  id       Int      @id @default(autoincrement())
  number   Int      @unique
  status   TableStatus @default(INATIVA)
  sessions TableSession[]
  createdAt DateTime @default(now())
}

model TableSession {
  id        String   @id @default(cuid())
  table     Table    @relation(fields: [tableId], references: [id])
  tableId   Int
  openedAt  DateTime @default(now())
  closedAt  DateTime?
  orders    Order[]
}

model Order {
  id           String       @id @default(cuid())
  session      TableSession @relation(fields: [sessionId], references: [id])
  sessionId    String
  customerName String
  clientId     String       @default("")
  status       OrderStatus  @default(PREPARANDO)
  items        OrderItem[]
  createdAt    DateTime     @default(now())
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     String
  menuItemId  String
  name        String
  price       Float
  quantity    Int
  observation String  @default("")
}

model MenuItem {
  id          String          @id
  name        String
  description String
  price       Float
  category    MenuCategory
  image       String
  badge       String?
  active      Boolean         @default(true)
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
}

enum MenuCategory {
  bebidas
  petiscos
  refeicoes
  sobremesas
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(GARCOM)
  createdAt    DateTime @default(now())
}

enum UserRole {
  DONO
  GARCOM
}

enum TableStatus {
  LIVRE
  OCUPADA
  INATIVA
}

enum OrderStatus {
  PREPARANDO
  PRONTO
  ENTREGUE
}
